# Groq: la IA que compara los pensum de origen y destino. Solo se usa en el servidor.
GROQ_API_KEY=

# Conexión a Supabase. La URL y la anon key viajan al navegador, por eso el prefijo NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# La service role da acceso total a la base de datos: jamás debe salir del servidor.
SUPABASE_SERVICE_ROLE_KEY=
