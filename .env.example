# Groq: la IA que empareja las materias del PDF de origen con el pensum destino. Solo backend.
GROQ_API_KEY=

# Supabase local: lo que imprime `supabase start` (o `pnpm db:status` para volver a verlo).
# La URL y la publishable key viajan al navegador, por eso el prefijo NEXT_PUBLIC_.
# Son claves de desarrollo local; en producción se reemplazan por las del proyecto hosted.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# La secret key reemplaza a la vieja service_role: acceso total saltándose las reglas RLS.
# Solo se usa en el servidor para tareas de admin. Jamás debe llegar al navegador.
SUPABASE_SECRET_KEY=

# URL pública del sitio (sin barra final). Se usa para armar enlaces absolutos: el QR del acta y el
# enlace de seguimiento del correo ({SITIO}/seguimiento/{token}). En desarrollo, http://localhost:3000.
# En producción (Vercel): configúrala con tu dominio. Si la omites, el código cae automáticamente a
# VERCEL_PROJECT_PRODUCTION_URL (dominio estable del proyecto) — que Vercel inyecta solo — así que NO
# volverá a apuntar a localhost. Ver src/lib/sitio.ts.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile (captcha anti-bots del formulario público de homologación). Si AMBAS están
# vacías, el captcha queda DESACTIVADO (el widget no se muestra y el servidor omite la verificación).
# Para ACTIVARLO en producción:
#   1. Crea un widget en https://dash.cloudflare.com/?to=/:account/turnstile y agrega el dominio de
#      Vercel (y cualquier dominio propio) en la lista de dominios permitidos del widget.
#   2. Copia el Site Key y el Secret Key aquí.
#   3. En Vercel, define AMBAS variables ANTES del build: NEXT_PUBLIC_TURNSTILE_SITE_KEY se "hornea" en
#      el bundle del navegador en tiempo de build, así que no basta con agregarla y re-deployar sin
#      reconstruir. Con las dos configuradas, el formulario exige resolver el captcha para enviar.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Correo del veredicto/recepción (producción: Resend). Sin RESEND_API_KEY no se envía correo (no-op),
# el flujo no se rompe. Requiere un dominio verificado en Resend para escribir a cualquier estudiante.
RESEND_API_KEY=
CORREO_REMITENTE="Homologaciones <onboarding@resend.dev>"
