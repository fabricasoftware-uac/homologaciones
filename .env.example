# Groq: la IA que empareja las materias del PDF de origen con el pensum destino. Solo backend.
GROQ_API_KEY=

# Supabase local: lo que imprime `supabase start` (o `pnpm db:status` para volver a verlo).
# La URL y la publishable key viajan al navegador, por eso el prefijo NEXT_PUBLIC_.
# Son claves de desarrollo local; en producción se reemplazan por las del proyecto hosted.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# La secret key reemplaza a la vieja service_role: acceso total saltándose las reglas RLS.
# Solo se usa en el servidor para tareas de admin. Jamás debe llegar al navegador.
SUPABASE_SECRET_KEY=

# URL pública del sitio (sin barra final). Se usa para armar el enlace de seguimiento que viaja en
# el correo del veredicto: {SITIO}/seguimiento/{token}. En desarrollo, http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
